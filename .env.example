# Optional: Google Gemini API key for Voice lesson speech-to-text / evaluation
# Get a key at https://aistudio.google.com/apikey
# Copy this file to .env and uncomment the line below for AI speech grading on web & mobile.
# Expo exposes only EXPO_PUBLIC_* vars to the app bundle — never commit real keys.
# EXPO_PUBLIC_GEMINI_API_KEY=your_key_here
# Optional model override (default: gemini-2.0-flash)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
# Gemini Live native-audio model (voice tutor — WebSocket)
# EXPO_PUBLIC_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
#
# Gemini powers: Voice lesson grading, Live Voice Tutor (/voice-tutor)

# Optional: HTTPS endpoint for AI Teacher scoring (POST JSON body)
# EXPO_PUBLIC_AI_TEACHER_URL=https://your-api.example.com/v1/evaluate

# Optional: Bearer token for AI Teacher API
# EXPO_PUBLIC_AI_TEACHER_API_KEY=

# Optional: hosted privacy policy URL for store listings
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-site.example.com/privacy

# Optional: Sentry crash reporting (https://sentry.io — create a React Native project)
# Set in EAS production/preview secrets — required for production crash reports.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# EXPO_PUBLIC_SENTRY_DEBUG=1

# Optional: legacy Boson TTS (deprecated route /role-play redirects to /roleplay)
# Prefer removing client keys; use a backend proxy in production.
# EXPO_PUBLIC_BOSON_API_KEY=

# Force JS floating tab bar on Android dev builds (Expo Go uses this automatically)
# EXPO_PUBLIC_ANDROID_JS_TABS=1

# Android dev client can't reach Metro? Use your PC's LAN IP (ipconfig) or tunnel:
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.19
# Then: npx expo start --dev-client --clear
# Or: npx expo start --tunnel
