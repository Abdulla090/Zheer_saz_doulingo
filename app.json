{
  "expo": {
    "name": "Phingo English",
    "slug": "duolingo-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "duolingoclone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.hewad.mubariz.duolingoclone",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hewad.mubariz.duolingoclone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Phingo English to use the microphone for speaking practice.",
          "speechRecognitionPermission": "Allow Phingo English to transcribe your speech for lessons and AI feedback."
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.hewad.mubariz.duolingoclone",
          "widgets": [
            {
              "name": "PhingoHome",
              "displayName": "Phingo",
              "description": "Streak, daily XP, path progress, and your next lesson",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PhingoHome",
              "label": "Phingo",
              "description": "Streak, XP, and your next lesson",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "targetCellWidth": 5,
              "targetCellHeight": 2,
              "resizeMode": "horizontal",
              "previewImage": "./assets/images/icon.png"
            }
          ],
          "fonts": [
            "./assets/fonts/DIN_BOLD.ttf",
            "./assets/fonts/DIN_MEDIUM.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57df22e9-341f-4e45-a08d-fb5ca28d69c5"
      }
    },
    "owner": "abdulla001"
  }
}
