{
  "expo": {
    "name": "Phingo English",
    "slug": "duolingo-clone",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "duolingoclone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.hewad.mubariz.duolingoclone",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hewad.mubariz.duolingoclone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Phingo English to use the microphone for speaking practice.",
          "speechRecognitionPermission": "Allow Phingo English to transcribe your speech for lessons and AI feedback."
        }
      ],
      "./plugins/with-normalize-android-receivers.js",
      "./plugins/with-android-widget-resources.js",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.hewad.mubariz.duolingoclone",
          "widgets": [
            {
              "name": "PhingoStreak",
              "displayName": "Phingo Streak",
              "description": "Your daily streak and XP progress at a glance",
              "supportedFamilies": ["systemSmall"],
              "ios": { "supportedFamilies": ["systemSmall"] },
              "android": {
                "targetCellWidth": 2,
                "targetCellHeight": 2,
                "minWidth": 110,
                "minHeight": 110
              }
            },
            {
              "name": "PhingoDailyXp",
              "displayName": "Phingo Daily XP",
              "description": "Track daily XP goal and streak",
              "supportedFamilies": ["systemSmall"],
              "ios": { "supportedFamilies": ["systemSmall"] },
              "android": {
                "targetCellWidth": 2,
                "targetCellHeight": 2,
                "minWidth": 110,
                "minHeight": 110
              }
            },
            {
              "name": "PhingoNextLesson",
              "displayName": "Phingo Next Lesson",
              "description": "See your next lesson and jump back in",
              "supportedFamilies": ["systemSmall", "systemMedium"],
              "ios": { "supportedFamilies": ["systemSmall", "systemMedium"] },
              "android": {
                "targetCellWidth": 4,
                "targetCellHeight": 2,
                "resizeMode": "horizontal"
              }
            },
            {
              "name": "PhingoProgress",
              "displayName": "Phingo Paths",
              "description": "Dual-path progress for Kurdish and English",
              "supportedFamilies": ["systemMedium"],
              "ios": { "supportedFamilies": ["systemMedium"] },
              "android": {
                "targetCellWidth": 4,
                "targetCellHeight": 3,
                "resizeMode": "vertical"
              }
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57df22e9-341f-4e45-a08d-fb5ca28d69c5"
      }
    },
    "owner": "abdulla001"
  }
}
