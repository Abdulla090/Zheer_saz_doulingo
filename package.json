  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "expo-mcp": "~0.2.1",
    "playwright": "^1.49.1",
    "react-grab": "^0.1.44",
