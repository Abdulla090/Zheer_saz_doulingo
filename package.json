{
  "name": "duolingo-clone",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "start": "expo start",
    "start:mcp": "node ./scripts/start-with-mcp.js",
    "start:emu": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-emulator.ps1",
    "start:emu:mcp": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-emulator.ps1 mcp",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android --clean",
    "web": "expo start --web",
    "web:mcp": "node ./scripts/start-with-mcp.js --web",
    "lint": "expo lint",
    "verify": "node scripts/verify-release.mjs",
    "eas-build-pre-install": "node scripts/eas-pre-install.mjs",
    "build:apk": "npx eas-cli build --platform android --profile preview --non-interactive"
  },
  "dependencies": {
    "@expo/ui": "~56.0.14",
    "@legendapp/list": "^3.0.0-beta.43",
    "@react-native-async-storage/async-storage": "^2.1.2",
