{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EXPO_PUBLIC_GEMINI_MODEL": "gemini-3.5-flash",
        "EXPO_PUBLIC_GEMINI_LIVE_MODEL": "gemini-3.1-flash-live-preview",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EXPO_PUBLIC_GEMINI_MODEL": "gemini-3.5-flash",
        "EXPO_PUBLIC_GEMINI_LIVE_MODEL": "gemini-3.1-flash-live-preview",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
