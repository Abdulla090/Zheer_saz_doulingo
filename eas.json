{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production",
        "NPM_CONFIG_OPTIONAL": "false",
        "BUN_CONFIG_NO_OPTIONAL": "1"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "env": {
        "NODE_ENV": "production",
        "NPM_CONFIG_OPTIONAL": "false",
        "BUN_CONFIG_NO_OPTIONAL": "1"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
